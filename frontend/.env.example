# ============================================================================
# DropSafe Frontend Environment Configuration
# ============================================================================
#
# Vite configuration (automatically loaded in React app)
# All variables must be prefixed with VITE_ to be exposed to frontend
#
# Copy this file: cp .env.example .env.local
# Then fill in values below
#
# Note: In Vite, variables are baked into the bundle at build time.
# Never commit actual .env or .env.local files to git!
#
# ============================================================================

# ============================================================================
# API CONFIGURATION (Required)
# ============================================================================

# Backend API URL
# Development: http://localhost:8000 (local FastAPI server)
# Staging: https://api-staging.dropsafe.com
# Production: https://api.dropsafe.com
#
# This is where all frontend API calls are sent:
# - GET /dashboard/stats
# - GET /fraud/alerts
# - POST /fraud/claims/{id}/approve
# - etc.
VITE_API_URL=http://localhost:8000

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# App display name
# Used in:
# - Browser tab title
# - Header/branding
# - Window title
VITE_APP_NAME=DropSafe

# App version (semantic versioning)
# Format: MAJOR.MINOR.PATCH
# Examples:
# - 1.0.0 (initial release)
# - 2.0.0 (major rewrite with new features)
# - 2.1.3 (bug fixes and patches)
#
# Update this when deploying new versions
VITE_APP_VERSION=2.0.0

# ============================================================================
# FEATURE FLAGS (Optional - controls which features are enabled)
# ============================================================================

# Enable/disable analytics tracking
# true: Send analytics data to services (if configured)
# false: No analytics sent
# Default: false (privacy-first)
VITE_ENABLE_ANALYTICS=false

# Enable debug mode (verbose console logging)
# true: Development (lots of console logs)
# false: Production (minimal logging)
#
# When enabled:
# - API requests/responses logged to console
# - Component re-renders logged
# - State changes visible in dev tools
# - Performance timings shown
VITE_DEBUG_MODE=false

# ============================================================================
# OPTIONAL: MONITORING & ANALYTICS
# ============================================================================
# Uncomment if using external services

# Google Analytics (optional)
# Get from: Google Analytics → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# PostHog (product analytics)
# Get key from: PostHog Project Settings
# VITE_POSTHOG_API_KEY=ph_your_key
# VITE_POSTHOG_API_HOST=https://posthog.yoursite.com

# Sentry (error tracking)
# Get DSN from: Sentry Project Settings
# VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================================================
# BUILD & DEPLOYMENT CONFIGURATION
# ============================================================================

# Environment (automatically set by build tools)
# Values: development | staging | production
# Controlled by: npm run dev (development)
#               npm run build (production)
# ENV=development

# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================
#
# Starting development server:
# 1. Create .env.local from .env.example:
#    cp .env.example .env.local
#
# 2. Fill in VITE_API_URL (must match your backend)
#
# 3. Start dev server:
#    npm run dev
#    Server runs at: http://localhost:5173
#
# Building for production:
# npm run build          # Creates optimized build in dist/
# npm run preview        # Preview production build locally
# npm run export         # Export static site
#
# Files that are committed to git:
# ✓ .env.example (template with no secrets)
# ✗ .env (local development, ignore)
# ✗ .env.local (local overrides, ignore)
# ✗ .env.production (production secrets, ignore)
#
# How Vite loads environment files:
# 1. .env (shared by all environments)
# 2. .env.local (local overrides, never committed)
# 3. .env.[mode] (e.g., .env.development, .env.production)
# 4. .env.[mode].local (mode-specific local overrides)
#
# All variables must start with VITE_ to be exposed to client
# (browser sees them - they're not secrets!)
#
# Security note:
# DO NOT put secret API keys in frontend .env
# Frontend environment variables are visible in browser
# Use backend APIs to call protected services
#
# ============================================================================
