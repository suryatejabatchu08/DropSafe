{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "env": {
    "VITE_API_BASE_URL": "@vite_api_base_url"
  },
  "rewrites": [
    {
      "source": "/api/*(.*)",
      "destination": "/api$1"
    },
    {
      "source": "/(?!(?:assets|favicon).*)",
      "destination": "/index.html"
    }
  ]
}


