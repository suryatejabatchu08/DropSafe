# DropSafe Environment Variables
# Copy this file to .env and fill in your actual values

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co

# IMPORTANT: Use SERVICE_ROLE_KEY for backend (not anon key!)
# Service role bypasses RLS and has full database access
# NEVER commit this key to git or expose it publicly
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anon key (optional - used only for frontend if needed)
SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase Service Role Key (for admin operations)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Razorpay Configuration (for payouts)
# RAZORPAY_KEY_ID=your-razorpay-key-id
# RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# WhatsApp Business API (for notifications)
# WHATSAPP_API_KEY=your-whatsapp-api-key
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# External Data Sources
# IMD_API_KEY=your-imd-api-key
# CPCB_API_KEY=your-cpcb-api-key
