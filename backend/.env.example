# ============================================================================
# DropSafe Backend Environment Configuration
# ============================================================================
#
# Copy this file: cp .env.example .env
# Then fill in your actual credentials
#
# ⚠️ SECURITY WARNINGS:
# - NEVER commit .env to git (only .env.example)
# - All keys marked [SENSITIVE] must be kept SECRET
# - Rotate keys regularly in production
# - Use different keys for dev/test/production
#
# ============================================================================

# ============================================================================
# SUPABASE: PostgreSQL Database (Required)
# ============================================================================
# Sign up: https://app.supabase.com
# Get values from: Project Settings → API
# Format: https://[project-ref].supabase.co

# Your Supabase project URL
# Example: https://pypsfbnqhiqobvtatybg.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Anonymous Key for client-side access
# Location: Dashboard → Settings → API Keys → `anon` key
# Safe to expose (read-only, limited by Row-Level Security)
SUPABASE_KEY=your_supabase_anon_key

# Service Role Key [SENSITIVE - Backend Only!]
# Location: Dashboard → Settings → API Keys → `service_role` key
# ⚠️ CRITICAL: Bypasses RLS, has full database access
# ⚠️ MUST be stored securely in backend .env
# ⚠️ NEVER expose in frontend or public APIs
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ============================================================================
# RAZORPAY: Payment Processing (Required for payouts)
# ============================================================================
# Sign up: https://razorpay.com
# Dashboard: https://dashboard.razorpay.com
#
# KEY POINTS:
# - Test keys start with "rzp_test_" (for development)
# - Production keys start with "rzp_live_" (for production only)
# - Test card: 4111 1111 1111 1111
# - Test CVV: Any 3 digits (e.g., 123)
# - Test OTP: 1234
# - Only auto-approve in test mode

# Test API Key ID
# Get from: Dashboard → Settings → API Keys → Key ID
# Example: rzp_test_SXuLkQfcfRquMY
RAZORPAY_KEY_ID=rzp_test_your_key_id

# Test API Key Secret [SENSITIVE - Backend Only!]
# Get from: Dashboard → Settings → API Keys → Key Secret
# ⚠️ CRITICAL: Authorizes all payout transactions
# ⚠️ NEVER expose publicly or in frontend
# Example: yoOzDzkscT6GGiD1aL6qhRXq
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Razorpay Webhook Secret [SENSITIVE]
# Used to verify payment webhook signatures from Razorpay
# Get from: Dashboard → Webhooks → [Your webhook] → Show secret
# Example: whsec_xxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ============================================================================
# TWILIO: WhatsApp Messaging (Required for worker notifications)
# ============================================================================
# Sign up: https://www.twilio.com
# Console: https://www.twilio.com/console
#
# TEST SETUP:
# 1. Go to: https://www.twilio.com/console/sms/whatsapp/learn
# 2. Copy your Sandbox Phone Number
# 3. Get Account SID and Auth Token from Console
# 4. For testing: Message "join <code>" to sandbox number

# Twilio Account SID
# Get from: Console → Account SID (right sidebar)
# Example: AC93f153d2eb520a2c55f56d8e8b3eeac4
TWILIO_ACCOUNT_SID=your_account_sid

# Twilio Auth Token [SENSITIVE - Backend Only!]
# Get from: Console → Auth Token (click "Show")
# ⚠️ CRITICAL: Authorizes all WhatsApp messages
# ⚠️ NEVER expose in frontend or public code
# Example: 32f09a9c811549ae0f023015bb4e57c8
TWILIO_AUTH_TOKEN=your_auth_token

# Twilio WhatsApp Number (from Sandbox)
# For Testing: whatsapp:+14155238886 (Twilio sandbox - no phone needed)
# Production: whatsapp:+91XXXXXXXXXX (Your WhatsApp Business Account)
# Must include "whatsapp:" prefix
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================================================
# WEATHER & AIR QUALITY APIs (Required for trigger detection)
# ============================================================================

# WeatherAPI: Real-time weather data
# Sign up: https://www.weatherapi.com
# Get key: Dashboard → API Key
# Used for: Rain ≥50mm, Temperature ≥43°C triggers
# Rate limit: 1 call/sec, Free tier: 1M calls/month
# Caching: 10 minutes per zone (to minimize API calls)
WEATHERAPI_KEY=your_weatherapi_key

# IQAir: Air Quality Index (AQI)
# Sign up: https://www.iqair.com/api
# Get key: Dashboard → API Keys
# Used for: AQI ≥400 trigger detection
# Rate limit: Free tier 10,000 calls/month
# Caching: 10 minutes per zone
IQAIR_API_KEY=your_iqair_api_key

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Base URL: ngrok tunnel for local development
# ⚠️ IMPORTANT: Changes every time you restart ngrok!
#
# STEPS:
# 1. Open new terminal
# 2. Run: ngrok http 8000
# 3. Copy the "Forwarding" URL (e.g., https://1234-56-789-012-34.ngrok.io)
# 4. Paste here: BASE_URL=https://1234-56-789-012-34.ngrok.io
# 5. Restart backend: python -m uvicorn main:app --reload
#
# Used for:
# - WhatsApp webhooks (Twilio → ngrok → backend)
# - Razorpay payment confirmations
# - Any external service callbacks
#
# Production: Use your actual domain (e.g., https://api.dropsafe.com)
BASE_URL=https://your-ngrok-url.ngrok.io

# Frontend URL (for CORS headers and redirects)
# Development: http://localhost:5173 (Vite dev server)
# Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# ============================================================================
# DATABASE: Direct PostgreSQL Connection (Optional)
# ============================================================================
# Format: postgresql://user:password@host:port/database
#
# Supabase Database Connection:
# 1. Dashboard → Settings → Database
# 2. Copy connection string
# 3. Replace [PASSWORD] with your database password
#
# Example: postgresql://postgres:your-password@db.pypsfbnqhiqobvtatybg.supabase.co:5432/postgres
# Local: postgresql://postgres:password@localhost:5432/dropsafe

# DATABASE_URL=postgresql://postgres:your-password@localhost:5432/dropsafe

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Enable debug mode (verbose logging)
# True: Development (lots of logs, slow)
# False: Production (less noisy)
DEBUG=False

# Log level threshold
# DEBUG: Everything (very verbose, for development)
# INFO: Normal operation information (standard)
# WARNING: Potential issues that don't break app
# ERROR: Problems requiring attention
# CRITICAL: System-breaking errors
LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL: MONITORING & ERROR TRACKING
# ============================================================================
# Uncomment if using these services

# Sentry (Error tracking and crash reporting)
# Sign up: https://sentry.io
# Get DSN from: Project Settings → Client Keys (DSN)
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# DataDog (Cloud monitoring - optional)
# DATADOG_API_KEY=your_datadog_key

# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================
#
# Running locally:
# 1. Create .env from .env.example: cp .env.example .env
# 2. Fill in all credentials above
# 3. Start ngrok: ngrok http 8000
# 4. Update BASE_URL in .env with ngrok URL
# 5. Start backend: cd backend && python -m uvicorn main:app --reload
#
# Testing without credentials:
# - Mock data: Some services have mock/sandbox modes (Razorpay test keys, Twilio sandbox)
# - Environment variable defaults: Some fallback to reasonable defaults if not set
#
# Security checklist:
# ✓ .env is in .gitignore
# ✓ .env.example is committed (without secrets)
# ✓ All [SENSITIVE] keys are kept SECRET
# ✓ Different keys for dev/prod environments
# ✓ Keys rotated regularly
# ✓ Never hardcoded API keys in code
#
# ============================================================================
# PHASE 3 — SCALE & OPTIMISE (New in v3.0)
# ============================================================================

# Predictive analytics in-memory cache TTL (seconds)
# Higher = fewer WeatherAPI calls; lower = fresher forecast data
# Default: 3600 (1 hour)
PREDICTIVE_CACHE_TTL_SECONDS=3600

# ML model directory (relative to backend/)
# Default: models/ (auto-created on startup)
# MODELS_DIR=models

# Isolation Forest auto-train on startup (True/False)
# If False, model must be trained manually via POST /ml/train
# Default: True (auto-trains on synthetic data if no model exists)
# IF_AUTO_TRAIN=True

# ============================================================================
